# =========================
# Local Development (.env)
# =========================

# Frontend (Vite)
# Leave empty to use Vite proxy (/api -> http://localhost:4000)
VITE_API_BASE_URL=""

# Backend (Node/Express)
# If you use Prisma local Postgres, replace PORT with the value printed by `npm run db:dev`
DATABASE_URL="postgresql://postgres:postgres@localhost:PORT/portfolio?schema=public&sslmode=disable&pgbouncer=true"
FRONTEND_URL="http://localhost:5173"
PORT="4000"
ADMIN_SECRET="change-this-local-admin-secret"


# ===============================
# Production Deployment (example)
# ===============================

# Frontend (Vercel)
# VITE_API_BASE_URL="https://your-render-service.onrender.com"

# Backend (Render)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public&sslmode=require"
# FRONTEND_URL="https://your-vercel-project.vercel.app"
# PORT="4000"
# ADMIN_SECRET="set-a-strong-secret"
