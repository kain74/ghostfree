generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Post {
    id        Int      @id @default(autoincrement())
    title     String
    author    String   @default("익명")
    passwordHash String @default("")
    content   String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}